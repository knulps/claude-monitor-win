[claude]
cookies       = sessionKey=sk-ant-...; cf_clearance=...; ...
org_id        = xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
poll_interval = 60

[ui]
language = en              ; en | ko
mode     = overlay         ; overlay | tray | cli | autohide

[tray]
popup_position = above     ; above | below

[autohide]
edge          = right      ; right | left | top | bottom
peek_pixels   = 3
slide_ms      = 150
hide_delay_ms = 1500
